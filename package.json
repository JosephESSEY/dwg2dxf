{
  "name": "dwg2dxf-converter",
  "version": "1.0.2",
  "description": "DWG to DXF converter — 100% standalone, no dependencies, powered by LibreDWG WebAssembly",
  "main": "index.js",
  "types": "index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "bash ./scripts/build-wasm.sh",
    "test": "node test/test.js",
    "prepublishOnly": "node -e \"if (!require('fs').existsSync('wasm/libredwg.wasm')) { console.error('Build required avant publication !'); process.exit(1); }\""
  },
  "files": [
    "wasm/",
    "lib/",
    "index.js",
    "index.d.ts"
  ],
  "keywords": [
    "dwg",
    "dxf",
    "dwg-to-dxf",
    "dwg2dxf",
    "autocad",
    "autocad-converter",
    "libredwg",
    "cad",
    "cad-converter",
    "conversion",
    "wasm",
    "webassembly",
    "dwg-parser",
    "dxf-converter",
    "cad-file-converter",
    "dwg-reader",
    "autocad-dwg",
    "r14",
    "surveying",
    "gis"
  ],
  "author": "JosephESSEY",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JosephESSEY/dwg2dxf.git"
  },
  "bugs": {
    "url": "https://github.com/JosephESSEY/dwg2dxf/issues"
  },
  "homepage": "https://github.com/JosephESSEY/dwg2dxf#readme"
}
